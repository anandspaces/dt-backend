NODE_ENV=development
PORT=4000

# Set true to serve /api/docs and /api/openapi.json in production (default: off in production)
ENABLE_API_DOCS=false

# sqlite | postgresql
DATABASE_DRIVER=sqlite
# SQLite: path after file: is relative to cwd unless absolute
DATABASE_URL=file:./data/app.db
# After schema changes, apply migrations (Bun SQLite — avoids better-sqlite3 / Node ABI issues):
#   bun run db:migrate:sqlite

# JWT
JWT_SECRET=change-me-in-production-min-32-chars-long
JWT_EXPIRES_IN=7d

# Google Gemini (model name only via env — no hardcoding in app code)
GEMINI_API_KEY=
GEMINI_MODEL=

# Full PDF pipeline: optional Gemini native TTS (same API key as above). Omit GEMINI_TTS_MODEL to skip TTS.
# Example: gemini-2.5-flash-preview-tts or gemini-3.1-flash-tts-preview
GEMINI_TTS_MODEL=
GEMINI_TTS_VOICE=
# Optional voice for Hindi TTS in parse-export; falls back to GEMINI_TTS_VOICE then Kore.
GEMINI_TTS_VOICE_HI=

# Optional: Gemini model id for parse-export illustration images (different from GEMINI_MODEL text model).
# When unset, image cells are skipped and the text brief is still produced via GEMINI_MODEL in the manifest.
# Check current Google AI image-capable model names for your account/region.
# Example (verify in Google AI docs): gemini-2.0-flash-preview-image-generation
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
# Optional aspect ratio for image generation API (imageConfig); e.g. 3:4 for portrait illustrations.
# GEMINI_IMAGE_ASPECT_RATIO=3:4
# Raise if Gemini 3 image returns only text+thoughtSignature (reasoning uses output budget).
# GEMINI_IMAGE_MAX_OUTPUT_TOKENS=32768

# Parallel page analysis / TTS workers (defaults: 8 / 4)
INGESTION_PAGE_CONCURRENCY=8
INGESTION_TTS_CONCURRENCY=4
TTS_MAX_ATOMS=300

# Storage: local | s3
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads

# Optional S3-compatible
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Optional Redis (HTTP cache). Required when JOB_QUEUE_DRIVER=redis (BullMQ + `bun run worker`).
# Local BullMQ example:
# REDIS_URL=redis://127.0.0.1:6379
REDIS_URL=
# in_memory | redis — redis uses BullMQ; run worker: bun run worker
JOB_QUEUE_DRIVER=in_memory
# Dev only: `bun dev` runs scripts/clear-bull-queue-dev.ts first — obliterates BullMQ queue + pe:p:* progress keys.
# Set to 1 to keep Redis queue/progress between dev restarts.
# DEV_SKIP_CLEAR_BULL_QUEUE=
# Parallel job slots for in-memory queue (and BullMQ worker concurrency).
# Increase to 20-50 for fast local processing; cap lower when Gemini rate-limits.
PARSE_EXPORT_WORKER_CONCURRENCY=20
# Concurrent Gemini/HTML sub-tasks inside one parse-export atom (and topic) job
PARSE_EXPORT_ATOM_INTERNAL_CONCURRENCY=6
# Chapter comic: max pages in story output
PARSE_EXPORT_COMIC_CHAPTER_MAX_PAGES=4
# Chapter comic: page image generation concurrency
PARSE_EXPORT_COMIC_PAGE_CONCURRENCY=3
# Optional public API origin for absolute artifact URLs (e.g. TTS audioUrl). No trailing slash.
PUBLIC_API_BASE_URL=
# relaxed | strict — HTML game verification for parse-export (SVG/MathML friendly vs tighter)
PARSE_EXPORT_HTML_VERIFY_MODE=relaxed
# Max HTML size (bytes) for parse-export game verification
PARSE_EXPORT_HTML_MAX_BYTES=600000

# Parse-export async TTS: SuperTTS HTTP POST JSON { text, language }. When set, workers prefer SuperTTS over Gemini TTS.
SUPERTTS_HTTP_URL=
SUPERTTS_LANGUAGE=en

# Rate limit (requests per window per IP)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
