NODE_ENV=development
PORT=4000

# Set true to serve /api/docs and /api/openapi.json in production (default: off in production)
ENABLE_API_DOCS=false

# PostgreSQL connection string (postgres:// or postgresql://)
# Local example: postgresql://postgres@localhost:5432/dt_backend_db
# Production: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres@localhost:5432/dt_backend_db
# After schema changes: bun run db:generate && bun run db:migrate

# JWT
JWT_SECRET=change-me-in-production-min-32-chars-long
JWT_EXPIRES_IN=7d

# Google Gemini (model name only via env — no hardcoding in app code)
GEMINI_API_KEY=
# Optional: dedicated key for image REST API (parse-export illustrations/comics). Falls back to GEMINI_API_KEY.
# GEMINI_API_KEY_IMAGE=
GEMINI_MODEL=

# Optional: Gemini model id for parse-export illustration images.
# When unset, image cells are skipped and the text brief is still produced via GEMINI_MODEL.
# Uses GEMINI_API_KEY_IMAGE when set, else GEMINI_API_KEY.
# Example (verify in Google AI docs): gemini-2.0-flash-preview-image-generation
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
# Aspect ratio for Gemini image generation (preset). Default 4:5 ≈ portrait / near A4.
# GEMINI_IMAGE_ASPECT_RATIO=4:5
# GEMINI_IMAGE_MAX_OUTPUT_TOKENS=32768

# Parallel page analysis / TTS workers (defaults: 8 / 4)
INGESTION_PAGE_CONCURRENCY=8
INGESTION_TTS_CONCURRENCY=4
TTS_MAX_ATOMS=300

# Uploaded PDFs + parse-export blobs (local filesystem only).
STORAGE_LOCAL_DIR=./uploads

# Optional Redis (HTTP cache). Required when JOB_QUEUE_DRIVER=redis (BullMQ + `bun run worker`).
REDIS_URL=redis://127.0.0.1:6379
# in_memory | redis — redis uses BullMQ; run worker: bun run worker
JOB_QUEUE_DRIVER=in_memory
# Dev only: `bun dev` runs scripts/clear-bull-queue-dev.ts first — obliterates BullMQ queue + pe:p:* progress keys.
# Set to 1 to keep Redis queue/progress between dev restarts.
# DEV_SKIP_CLEAR_BULL_QUEUE=
# Parallel job slots for in-memory queue (and BullMQ worker concurrency).
PARSE_EXPORT_WORKER_CONCURRENCY=20
# Concurrent Gemini/HTML sub-tasks inside one parse-export atom (and topic) job
PARSE_EXPORT_ATOM_INTERNAL_CONCURRENCY=6
# Chapter comic: max pages in story output
PARSE_EXPORT_COMIC_CHAPTER_MAX_PAGES=4
# Chapter comic: page image generation concurrency
PARSE_EXPORT_COMIC_PAGE_CONCURRENCY=3

# Public origin for absolute URLs outside parse-export artifacts (defaults in dev to http://localhost:<PORT>).
PUBLIC_API_BASE_URL=
# Optional: public base for parse-export file URLs only (audioUrl, fileUrl, htmlUrl). Overrides PUBLIC_API_BASE_URL when set.
# Production example: PUBLIC_ARTIFACT_BASE_URL=https://api.example.com
# PUBLIC_ARTIFACT_BASE_URL=
# Public file links: responses include `exp` + `sig` (HMAC) on /api/v1/files/audio?key=&mime= — no auth in the browser.
# Optional separate HMAC secret; defaults to JWT_SECRET. Link lifetime: FILE_URL_PUBLIC_TTL_SECONDS (default ~10y).
# FILE_URL_SIGNING_SECRET=
# FILE_URL_PUBLIC_TTL_SECONDS=315360000

# relaxed | strict — HTML game verification for parse-export (SVG/MathML friendly vs tighter)
PARSE_EXPORT_HTML_VERIFY_MODE=relaxed
# Max HTML size (bytes) for parse-export game verification
PARSE_EXPORT_HTML_MAX_BYTES=600000

# ─── Local Silero TTS (./silero-tts) ──────────────────────────────────────────
# Start the microservice: cd silero-tts && uv run uvicorn app:app --port 4001 --workers 4
# Set SILERO_CONCURRENCY in the microservice env to match --workers for concurrent inference.
# Required for parse-export TTS cells. When unset, TTS cells are skipped.
TTS_HTTP_URL=http://127.0.0.1:4001/tts
# Language code sent to Silero TTS (default en)
TTS_LANGUAGE=en
# Timeout tuning (ms): scales with input length
TTS_BASE_TIMEOUT_MS=90000
TTS_MAX_TIMEOUT_MS=480000
TTS_MAX_ATTEMPTS=4
# Long atom TTS: raise if you still see cell_deadline_exceeded on tts (default 420000 = 7 min)
# PARSE_EXPORT_TTS_CELL_TIMEOUT_MS=420000

# BullMQ cell deadlines
# PARSE_EXPORT_CELL_TIMEOUT_MS=180000
# Rate limit (requests per window per IP)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
